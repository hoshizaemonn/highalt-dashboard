# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require&pgbouncer=true&connection_limit=5"

# Session cookie signing secret (generate with: openssl rand -base64 48)
SESSION_SECRET="your-secret-key-here"

# Initial admin password (only used when seeding empty database)
ADMIN_INITIAL_PASSWORD="change-me"

# Auth (NextAuth - if used)
AUTH_SECRET="your-auth-secret-here"

# TLS (required for some Supabase connections)
NODE_TLS_REJECT_UNAUTHORIZED=0
