generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Users & Auth ───────────────────────────────────────────

model User {
  id          Int      @id @default(autoincrement())
  username    String   @unique
  password    String   @map("password_hash")
  role        String   @default("store_manager")
  storeName   String?  @map("store_name")
  displayName String?  @map("display_name")

  uploadLogs  UploadLog[]

  @@map("users")
}

// ─── Upload History ─────────────────────────────────────────

model UploadLog {
  id          Int      @id @default(autoincrement())
  userId      Int      @map("user_id")
  userName    String   @map("user_name")
  dataType    String   @map("data_type")
  storeName   String?  @map("store_name")
  year        Int?
  month       Int?
  fileName    String?  @map("file_name")
  recordCount Int      @default(0) @map("record_count")
  note        String?
  createdAt   DateTime @default(now()) @map("created_at")

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("upload_logs")
}

// ─── Store Overrides ────────────────────────────────────────

model StoreOverride {
  id           Int    @id @default(autoincrement())
  employeeId   Int    @map("employee_id")
  storeName    String @map("store_name")
  ratio        Int    @default(100)
  employeeName String @default("") @map("employee_name")

  @@unique([employeeId, storeName])
  @@map("store_overrides")
}

// ─── Expense Categories (勘定科目マスタ) ────────────────────

model ExpenseCategory {
  id           Int    @id @default(autoincrement())
  name         String @unique
  description  String @default("")
  examples     String @default("")
  categoryType String @default("expense") @map("category_type")

  @@map("expense_categories")
}

// ─── Expense Rules ──────────────────────────────────────────

model ExpenseRule {
  id       Int    @id @default(autoincrement())
  keyword  String @unique
  category String

  @@map("expense_rules")
}

// ─── Payroll Data ───────────────────────────────────────────

model PayrollData {
  id                    Int    @id @default(autoincrement())
  year                  Int
  month                 Int
  employeeId            String @map("employee_id")
  employeeName          String? @map("employee_name")
  contractType          String? @map("contract_type")
  storeName             String @map("store_name")
  ratio                 Int    @default(100)
  workDaysWeekday       Float  @default(0) @map("work_days_weekday")
  workDaysHoliday       Float  @default(0) @map("work_days_holiday")
  workDaysLegalHoliday  Float  @default(0) @map("work_days_legal_holiday")
  scheduledHours        Float  @default(0) @map("scheduled_hours")
  overtimeHours         Float  @default(0) @map("overtime_hours")
  baseSalary            Float  @default(0) @map("base_salary")
  positionAllowance     Float  @default(0) @map("position_allowance")
  overtimePay           Float  @default(0) @map("overtime_pay")
  commuteTaxable        Float  @default(0) @map("commute_taxable")
  commuteNontax         Float  @default(0) @map("commute_nontax")
  taxableTotal          Float  @default(0) @map("taxable_total")
  grossTotal            Float  @default(0) @map("gross_total")
  healthInsuranceCo     Float  @default(0) @map("health_insurance_co")
  careInsuranceCo       Float  @default(0) @map("care_insurance_co")
  pensionCo             Float  @default(0) @map("pension_co")
  childContributionCo   Float  @default(0) @map("child_contribution_co")
  pensionFundCo         Float  @default(0) @map("pension_fund_co")
  employmentInsuranceCo Float  @default(0) @map("employment_insurance_co")
  workersCompCo         Float  @default(0) @map("workers_comp_co")
  generalContributionCo Float  @default(0) @map("general_contribution_co")

  @@unique([year, month, employeeId, storeName])
  @@map("payroll_data")
}

// ─── Expense Data ───────────────────────────────────────────

model ExpenseData {
  id          Int     @id @default(autoincrement())
  year        Int
  month       Int
  day         Int
  storeName   String  @default("") @map("store_name")
  description String?
  amount      Float   @default(0)
  deposit     Float   @default(0)
  category    String?
  isRevenue   Int     @default(0) @map("is_revenue")
  breakdown   String  @default("")
  // 元CSVの該当行全体（JSON配列の文字列）。エクスポート時に元情報を欠落なく再出力するため保持。
  // 既存データ（rawRow=null）はフォールバックで従来7列出力。
  rawRow      String? @map("raw_row")
  // 発生主義の帰属年月（依頼⑥）。内訳の "N月" "N月分" "N月◯◯費" をパースして自動設定。
  // 集計時は COALESCE(accrual_year, year), COALESCE(accrual_month, month) を使用。
  // 既存データ（accrualYear/Month=null）は決済月で集計（従来通り）。
  accrualYear  Int? @map("accrual_year")
  accrualMonth Int? @map("accrual_month")
  // 取込元ファイル名（依頼: 2ファイル取込→エクスポートも2ファイル分割）。
  // 同月内で複数ファイルを取り込んだ場合、エクスポート時にこのキーで分割しZIPで返す。
  sourceFile   String? @map("source_file")
  // 1行の金額を複数店舗に按分する比率（JSON文字列、店舗→%）。
  // 例: '{"東日本橋":40,"中目黒":30,"船橋":30}' → amount を 40/30/30 で配分。
  // null の場合は storeName が示す店舗にそのまま計上（既存挙動）。
  // PayPay銀行で複数店舗分を一括支払いした場合に使う（依頼A）。
  splitRatios  String? @map("split_ratios")
  // 1行を複数科目に分解する設定（JSON文字列の配列）。
  // 例: '[{"category":"賃借料","amount":800000,"splitRatios":{"東日本橋":40,"中目黒":30,"船橋":30}},
  //      {"category":"電気料","amount":400000,"splitRatios":{"東日本橋":40,"中目黒":30,"船橋":30}}]'
  // categorySplits が設定されている場合、集計は行の category/amount/splitRatios を無視して
  // 各分解項目を独立に計上する（科目別かつ店舗別の二段按分）。
  // PayPay銀行で家賃+電気代等が一括出金される場合に使う。
  categorySplits String? @map("category_splits")

  @@index([year, month, storeName])
  @@index([accrualYear, accrualMonth, storeName])
  @@map("expense_data")
}

// ─── Expense CSV Header (取込時のヘッダ保持) ────────────────
// PayPay銀行/Square等のCSV取込時にヘッダ行を (year, month, storeName) 単位で保存し、
// エクスポート時に元の列構造をそのまま再現するために使う。
model ExpenseCsvHeader {
  id        Int    @id @default(autoincrement())
  year      Int
  month     Int
  storeName String @map("store_name")
  /**
   * ヘッダ列名の配列を JSON 文字列化したもの。例: ["年","月","日","曜日","摘要","出金","入金","残高",...]
   */
  headers   String

  @@unique([year, month, storeName])
  @@map("expense_csv_header")
}

// ─── Revenue Data ───────────────────────────────────────────

model RevenueData {
  id          Int     @id @default(autoincrement())
  year        Int
  month       Int
  storeName   String  @map("store_name")
  category    String  @default("売上")
  amount      Float   @default(0)
  memberCount Int     @default(0) @map("member_count")
  note        String?

  @@index([year, month, storeName])
  @@map("revenue_data")
}

// ─── Member Data (ML001) ────────────────────────────────────

model MemberData {
  id             Int     @id @default(autoincrement())
  year           Int
  month          Int
  storeName      String  @map("store_name")
  memberId       String? @map("member_id")
  memberName     String? @map("member_name")
  planName       String? @map("plan_name")
  joinDate       String? @map("join_date")
  tenure         String?
  isActive       Int     @default(1) @map("is_active")
  isNew          Int     @default(0) @map("is_new")
  hadTrial       Int     @default(0) @map("had_trial")
  planEndDate    String? @map("plan_end_date")
  trialDate      String? @map("trial_date")
  firstTrialDate String? @map("first_trial_date")
  initialPlan    String? @map("initial_plan")
  // 会員属性（坪井さん要望13: hacomono CSV由来）
  gender         String? @map("gender")
  birthdate      String? @map("birthdate")
  ageBucket      String? @map("age_bucket")

  @@unique([year, month, storeName, memberId])
  @@map("member_data")
}

// ─── Monthly Summary (MA002) ────────────────────────────────

model MonthlySummary {
  id                  Int    @id @default(autoincrement())
  year                Int
  month               Int
  storeName           String @default("") @map("store_name")
  totalMembers        Int    @default(0) @map("total_members")
  planSubscribers     Int    @default(0) @map("plan_subscribers")
  planSubscribers1st  Int    @default(0) @map("plan_subscribers_1st")
  newRegistrations    Int    @default(0) @map("new_registrations")
  newPlanApplications Int    @default(0) @map("new_plan_applications")
  newPlanSignups      Int    @default(0) @map("new_plan_signups")
  planChanges         Int    @default(0) @map("plan_changes")
  suspensions         Int    @default(0) @map("suspensions")
  cancellations       Int    @default(0) @map("cancellations")
  cancellationRate    String @default("") @map("cancellation_rate")

  @@unique([year, month, storeName])
  @@map("monthly_summary")
}

// ─── Sales Detail (PL001) ───────────────────────────────────

model SalesDetail {
  id            Int     @id @default(autoincrement())
  year          Int
  month         Int
  storeName     String  @map("store_name")
  saleId        String? @map("sale_id")
  saleDate      String? @map("sale_date")
  paymentMethod String? @map("payment_method")
  description   String?
  category      String?
  amount        Int     @default(0)
  tax           Int     @default(0)
  discount      Int     @default(0)

  @@index([year, month, storeName])
  @@map("sales_detail")
}

// ─── Square Sales ───────────────────────────────────────────

model SquareSales {
  id               Int    @id @default(autoincrement())
  year             Int
  month            Int
  storeName        String @map("store_name")
  grossSales       Int    @default(0) @map("gross_sales")
  netSales         Int    @default(0) @map("net_sales")
  fees             Int    @default(0)
  transactionCount Int    @default(0) @map("transaction_count")

  @@unique([year, month, storeName])
  @@map("square_sales")
}

// ─── Square Item Sales (商品別売上 / Square POS) ───────────
//
// Square POS の「アイテム別売上」CSV を取り込む。
// クライアント側で商品名に「パーソナル」「物販」等のキーワードを
// 入れて運用してもらい、取り込み時に classification に振り分ける。
//   パーソナル / 物販 / サービス / その他
// ダッシュボードの売上分類（パーソナル売上・物販売上）の優先ソースとなる。
model SquareItemSales {
  id             Int    @id @default(autoincrement())
  year           Int
  month          Int
  storeName      String @map("store_name")
  itemName       String @map("item_name")
  variation      String @default("") @map("variation")
  categoryRaw    String @default("") @map("category_raw")
  classification String @default("その他") // パーソナル / 物販 / サービス / その他
  quantity       Int    @default(0)
  grossSales     Int    @default(0) @map("gross_sales")
  netSales       Int    @default(0) @map("net_sales")
  discounts      Int    @default(0)
  refunds        Int    @default(0)

  @@unique([year, month, storeName, itemName, variation])
  @@index([year, month, storeName])
  @@index([year, month, storeName, classification])
  @@map("square_item_sales")
}

// ─── Manual Expense Entry (本部一括経費の手動入力) ──────────
//
// 電気代・水道代・家賃など、本部で一括契約・支払いされ各店の PayPay 銀行 CSV
// には現れない経費を、admin（松尾さん）が月次で入力する。
// 集計時は totalAmount / 営業店舗数 で各店に均等按分する（坪井さん要望）。
//
// 重要: PayPay 銀行 CSV にも該当カテゴリの支払いがある場合は二重計上になるため、
// クライアント運用ルールとして「本部一括分のみ」をここに入れる前提。
model ManualExpenseEntry {
  id              Int      @id @default(autoincrement())
  year            Int
  month           Int
  /** 経費カテゴリ名（BUDGET_ITEMS / EXPENSE_CATEGORIES と整合させる。例: 電気料, 上下水道料, 賃借料） */
  category        String
  /**
   * 計上先店舗。
   * - "" (空): 本部一括 → totalAmount を営業店舗数で均等按分
   * - 店舗名 (例: 東日本橋): その店舗のみに totalAmount を計上（按分しない）
   */
  storeName       String   @default("") @map("store_name")
  /** 本部一括 or 店舗別の金額（本部一括時は全店合算前の元金額、店舗別時はその店の金額） */
  totalAmount     Int      @default(0) @map("total_amount")
  /**
   * 手動按分の比率（JSON文字列）。storeName="" と組み合わせて使う。
   * 例: '{"東日本橋":40,"中目黒":30,"船橋":30}' → totalAmount を 40/30/30 で配分。
   * null の場合は既存挙動（""=均等按分、店舗名=単店計上）。
   */
  splitRatios     String?  @map("split_ratios")
  note            String?
  updatedByName   String?  @map("updated_by_name")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // 同一（年/月/カテゴリ/計上先）でも複数行を保存できるよう、ユニーク制約は付けない。
  // （本部一括経費で同じ費目を明細分けて複数登録したい要望に対応・松尾さん依頼#3）
  // 参照性能のため複合インデックスは維持する。
  @@index([year, month, category, storeName])
  @@index([year, month])
  @@map("manual_expense_entry")
}

// ─── Manual Payroll（人件費CSVに含まれない社員の手動追加） ──────
// クラウド給与の支給控除一覧表（CSV）に載らない社員（役員・業務委託・
// 未登録者など）の人件費を月次で手動追加する（松尾さん依頼⑥ 2026-07）。
// 集計時は amount を該当店舗・月の人件費（給与総額）に加算する。
model ManualPayrollEntry {
  id            Int      @id @default(autoincrement())
  year          Int
  month         Int
  /** 計上先店舗（必須。本部一括の概念は無く、必ずどこかの店舗に紐づく） */
  storeName     String   @map("store_name")
  /** 従業員名（表示用・任意） */
  employeeName  String?  @map("employee_name")
  /** 雇用区分（"正社員" / "アルバイト" 等・人数カウントの内訳表示用・任意） */
  contractType  String?  @map("contract_type")
  /** 給与総額（円）。人件費にそのまま加算する */
  amount        Int      @default(0)
  note          String?
  updatedByName String?  @map("updated_by_name")
  updatedAt     DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([year, month, storeName])
  @@index([year, month])
  @@map("manual_payroll_entry")
}

// ─── Budget Data ────────────────────────────────────────────

model BudgetData {
  id        Int    @id @default(autoincrement())
  storeName String @map("store_name")
  year      Int
  month     Int
  category  String
  amount    Int    @default(0)

  @@unique([storeName, year, month, category])
  @@map("budget_data")
}

// ─── Amazon Orders ──────────────────────────────────────────

model AmazonOrder {
  id              Int     @id @default(autoincrement())
  orderDate       String? @map("order_date")
  orderId         String? @map("order_id")
  storeName       String? @map("store_name")
  productName     String? @map("product_name")
  shortName       String? @map("short_name")
  amount          Int     @default(0)
  orderTotal      Int     @default(0) @map("order_total")
  paymentDate     String? @map("payment_date")
  deliveryAddress String? @map("delivery_address")
  asin            String  @default("")
  amazonCategory  String  @default("") @map("amazon_category")
  expenseCategory String  @default("") @map("expense_category")
  quantity        Int     @default(1)
  taxAmount       Int     @default(0) @map("tax_amount")
  taxRate         String  @default("") @map("tax_rate")
  accountUser     String  @default("") @map("account_user")
  invoiceNumber   String  @default("") @map("invoice_number")

  @@unique([orderId, productName])
  @@map("amazon_orders")
}

// ─── Amazon Product Master ──────────────────────────────────

model AmazonProductMaster {
  id              Int    @id @default(autoincrement())
  asin            String @unique
  productName     String @default("") @map("product_name")
  amazonCategory  String @default("") @map("amazon_category")
  expenseCategory String @map("expense_category")
  lastSeenDate    String @default("") @map("last_seen_date")
  updatedAt       String @default("") @map("updated_at")

  @@map("amazon_product_master")
}

// ─── Breakdown Rules ────────────────────────────────────────

model BreakdownRule {
  id          Int    @id @default(autoincrement())
  storeName   String @map("store_name")
  category    String
  subcategory String
  ratio       Float  @default(100)

  @@unique([storeName, category, subcategory])
  @@map("breakdown_rules")
}

// ─── Promotion Report (販促報告) ────────────────────────────

model PromotionReport {
  id                    Int    @id @default(autoincrement())
  year                  Int
  month                 Int
  storeName             String @map("store_name")

  // 体験数
  trialReferral         Int    @default(0) @map("trial_referral")
  trialNonReferral      Int    @default(0) @map("trial_non_referral")
  trialTotal            Int    @default(0) @map("trial_total")
  trialJoinRate         Float  @default(0) @map("trial_join_rate")
  trialSameDayRate      Float  @default(0) @map("trial_same_day_rate")

  // ポスティング
  postingStaff          Int    @default(0) @map("posting_staff")
  postingVendor         Int    @default(0) @map("posting_vendor")
  postingTotal          Int    @default(0) @map("posting_total")

  // 広告宣伝費 内訳
  adGoogle              Int    @default(0) @map("ad_google")
  adMeta                Int    @default(0) @map("ad_meta")
  adPosting             Int    @default(0) @map("ad_posting")
  adDesign              Int    @default(0) @map("ad_design")
  adPrint               Int    @default(0) @map("ad_print")
  adGift                Int    @default(0) @map("ad_gift")
  adEvent               Int    @default(0) @map("ad_event")
  adRecruit             Int    @default(0) @map("ad_recruit")
  adOther               Int    @default(0) @map("ad_other")
  adTotal               Int    @default(0) @map("ad_total")

  // 客単価
  unitPrice             Int    @default(0) @map("unit_price")

  // オプション
  optAthlete4           Int    @default(0) @map("opt_athlete_4")
  optAthlete8           Int    @default(0) @map("opt_athlete_8")
  optDrinkHyalchi       Int    @default(0) @map("opt_drink_hyalchi")
  optDrinkNmn           Int    @default(0) @map("opt_drink_nmn")
  optBoost4             Int    @default(0) @map("opt_boost_4")
  optBoost8             Int    @default(0) @map("opt_boost_8")

  // パーソナル・物販
  personalRevenue       Int    @default(0) @map("personal_revenue")
  merchandiseRevenue    Int    @default(0) @map("merchandise_revenue")

  // コメント
  comment               String @default("")

  @@unique([year, month, storeName])
  @@map("promotion_reports")
}

// ─── Product Sales (PS001 商品別売上) ──────────────────────
//
// hacomono の「商品別売上」CSV から取り込む。
// 月会費と入会金の正確な分離が PL001 摘要のキーワード判定では難しいため、
// 商品コード単位で集計したこのテーブルを客単価計算等に利用する。

model ProductSales {
  id           Int    @id @default(autoincrement())
  year         Int
  month        Int
  storeName    String @map("store_name")
  productCode  String @map("product_code")
  productName  String @map("product_name")
  totalCount   Int    @default(0) @map("total_count")
  saleCount    Int    @default(0) @map("sale_count")
  refundCount  Int    @default(0) @map("refund_count")
  couponCount  Int    @default(0) @map("coupon_count")
  totalAmount  Int    @default(0) @map("total_amount")

  @@unique([year, month, storeName, productCode])
  @@index([year, month, storeName])
  @@map("product_sales")
}

// ─── Manual Entry (店長手動追記) ─────────────────────────────
// 坪井さん要望: 体験者数（hacomonoに無いため手動）と
// 請求書ベースの「その他売上」を店長が月次で追記できるようにする。
model ManualEntry {
  id              Int      @id @default(autoincrement())
  year            Int
  month           Int
  storeName       String   @map("store_name")
  trialCount      Int      @default(0) @map("trial_count")
  /** 体験者のうち紹介経由の人数（店長手動入力。残りはそれ以外として扱う） */
  trialReferralCount Int   @default(0) @map("trial_referral_count")
  /**
   * その他売上（請求書ベース）の単一金額・メモ。
   * 複数件の内訳は ManualOtherSalesItem に記録する（互換のため本フィールドは残す）。
   */
  otherSalesAmount Int     @default(0) @map("other_sales_amount")
  otherSalesNote  String?  @map("other_sales_note")
  updatedByName   String?  @map("updated_by_name")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([year, month, storeName])
  @@map("manual_entry")
}

// ─── その他売上 内訳行（複数請求書対応） ───────────────────
// 1月に複数件の請求書がある場合に各行を分けて記録する。
// 集計時は (year, month, storeName) で sum(amount) を ManualEntry.otherSalesAmount
// より優先して使う。
model ManualOtherSalesItem {
  id          Int      @id @default(autoincrement())
  year        Int
  month       Int
  storeName   String   @map("store_name")
  amount      Int      @default(0)
  note        String?
  sortOrder   Int      @default(0) @map("sort_order")
  updatedByName String? @map("updated_by_name")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([year, month, storeName])
  @@map("manual_other_sales_item")
}

// ─── アンケート回答（hacomono enquete_answer 由来） ─────────
// 体験・入会アンケートを取り込み、ダッシュボードで認知経路/目的/頻度を集計する。
// 設問・選択肢は CSV のヘッダから動的に検出し、3カテゴリに正規化して格納する。
// 退会アンケートは取り込まない（坪井さん要望: 入会・体験のみ）。
model EnqueteAnswer {
  id                Int      @id @default(autoincrement())
  enqueteCode       String   @map("enquete_code")
  enqueteName       String?  @map("enquete_name")
  scene             String?
  storeName         String?  @map("store_name")
  registeredAt      String?  @map("registered_at")
  memberId          String   @map("member_id")
  gender            String?
  birthdate         String?
  age               Int?
  /** 認知経路（複数選択をカンマ区切りで保持） */
  awarenessChannels String?  @map("awareness_channels")
  /** 目的・達成したいこと */
  purposes          String?
  /** 現在の運動頻度（単一選択） */
  exerciseFrequency String?  @map("exercise_frequency")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@index([enqueteCode])
  @@index([storeName])
  @@index([memberId])
  @@map("enquete_answer")
}

// ─── 店舗表示名（坪井さん要望） ─────────────────────────────
// 内部 storeName（DBの紐付けキー）はそのままに、画面表示名のみを変更できるよう
// マッピングテーブルとして持つ。マッピングが無い店舗はそのまま storeName を表示。
//
// 例:
//   storeName="東日本橋" → displayName="東日本橋スタジオ"
//   ハコモノCSVは引き続き "東日本橋" で取り込まれ、データ整合性は保たれる。
model StoreDisplayName {
  id          Int      @id @default(autoincrement())
  storeName   String   @unique @map("store_name")
  displayName String   @map("display_name")
  /** 非表示フラグ: true の店舗は店舗リスト・店舗比較・集計から除外（閉店/テスト店舗用） */
  hidden      Boolean  @default(false)
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("store_display_name")
}

// ─── PL Actuals（前年比比較用・クライアント公式PL由来）──────────────
// クライアントの「開業からの実績累計（PL）」から取り込む月次の費目別実績。
// ダッシュボードの granular（PayPay自動仕分け）とは別系統で、
// 前年比比較を「同一ソース（公式PL）の当年 vs 前年」で内部整合させるために使う。
// 当年(9期)の値は翌期になれば自動的に前年(year-1)として比較対象になる。
// amount は円（PLは千円なので取込時に ×1000 して保存）。
model PlActual {
  id        Int    @id @default(autoincrement())
  storeName String @map("store_name")
  year      Int
  month     Int
  /** 費目キー: "人件費" / "消耗品費" / "広告宣伝費" */
  category  String
  /** 金額（円） */
  amount    Int    @default(0)

  @@unique([storeName, year, month, category])
  @@map("pl_actuals")
}

// ─── Login Rate Limit（ブルートフォース対策）────────────────────────
// Vercelサーバーレスではインメモリ状態がインスタンス間で共有されないため、
// ログイン失敗回数をDBで永続化する。テーブル未作成時はコード側で
// インメモリ方式にフォールバックする（scripts/sql/2026-07_login_attempts.sql 参照）。
model LoginAttempt {
  ip           String    @id
  count        Int       @default(0)
  firstAttempt DateTime  @map("first_attempt")
  lockedUntil  DateTime? @map("locked_until")

  @@map("login_attempts")
}
